{
  "name": "edubridge-web",
  "version": "1.0.0",
  "description": "EduBridge Multi-Platform Learning System - Web Application",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .jsx,.js",
    "lint:fix": "eslint src --ext .jsx,.js --fix",
    "format": "prettier --write \"src/**/*.{jsx,js,css,md}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.18.0",
    "redux": "^4.2.1",
    "react-redux": "^8.1.3",
    "@reduxjs/toolkit": "^1.9.7",
    "axios": "^1.6.2",
    "tailwindcss": "^3.3.6",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "heroicons": "^2.0.18",
    "react-toastify": "^9.1.3",
    "react-hook-form": "^7.48.1",
    "zod": "^3.22.4",
    "@hookform/resolvers": "^3.3.4",
    "date-fns": "^2.30.0",
    "clsx": "^2.0.0",
    "zustand": "^4.4.5",
    "framer-motion": "^10.16.7",
    "recharts": "^2.10.3",
    "socket.io-client": "^4.7.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "vite": "^5.0.7",
    "eslint": "^8.54.0",
    "eslint-config-react-app": "^7.0.1",
    "prettier": "^3.1.0",
    "typescript": "^5.3.2",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@testing-library/react": "^14.1.2",
    "@testing-library/jest-dom": "^6.1.5",
    "vitest": "^1.0.1",
    "@vitest/ui": "^1.0.1",
    "jsdom": "^22.1.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
