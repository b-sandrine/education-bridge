{
  "name": "EduBridge",
  "displayName": "EduBridge",
  "expo": {
    "name": "EduBridge",
    "slug": "edubridge",
    "version": "1.0.0",
    "scheme": "edubridge",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.aspirehaven.edubridge"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.aspirehaven.edubridge"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-camera",
      "expo-media-library",
      "expo-notifications"
    ]
  }
}
