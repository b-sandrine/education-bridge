# Backend Configuration

NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database Connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=edubridge_dev
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production
JWT_REFRESH_EXPIRE=30d

# External Services
AI_SERVICE_PROVIDER=openai
AI_API_KEY=sk-your-openai-api-key-here
AI_MODEL=gpt-4

# Email Configuration
EMAIL_SERVICE=sendgrid
EMAIL_FROM=noreply@edubridge.rw
SENDGRID_API_KEY=SG.your_sendgrid_key_here

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=AC_your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+250788000000

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_S3_BUCKET=edubridge-content

# USSD Gateway (Example: Africa's Talking)
USSD_GATEWAY_API_KEY=your_gateway_api_key
USSD_GATEWAY_USERNAME=your_username

# Google Analytics
GOOGLE_ANALYTICS_ID=UA_your_tracking_id

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:8100

# Session Configuration
SESSION_TIMEOUT=1800000

# File Upload
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=pdf,doc,docx,xls,xlsx,ppt,pptx,jpg,jpeg,png,mp4,webm

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Feature Flags
FEATURE_AI_CHATBOT=true
FEATURE_USSD=true
FEATURE_GAMIFICATION=true
