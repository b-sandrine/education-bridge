{
  "name": "edubridge-backend",
  "version": "1.0.0",
  "description": "EduBridge Multi-Platform Learning System - Backend API",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src --fix",
    "migrate": "node src/database/migrate.js",
    "seed": "node src/database/seed.js",
    "build": "echo 'Backend is interpreted, no build needed'",
    "docker:build": "docker build -t edubridge-backend .",
    "docker:run": "docker run -p 3000:3000 edubridge-backend"
  },
  "keywords": [
    "education",
    "learning",
    "africa",
    "rwanda",
    "inclusive"
  ],
  "author": "Sandrine - Aspire Haven Foundation",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "dotenv": "^16.0.3",
    "pg": "^8.10.0",
    "pg-pool": "^3.5.2",
    "jsonwebtoken": "^9.0.3",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "joi": "^17.11.0",
    "axios": "^1.6.2",
    "redis": "^4.6.11",
    "uuid": "^9.0.1",
    "nodemailer": "^6.9.7",
    "twilio": "^4.10.0",
    "multer": "^1.4.5-lts.1",
    "aws-sdk": "^2.1523.0",
    "winston": "^3.11.0",
    "express-async-errors": "^3.1.1",
    "xss": "^1.0.14",
    "express-mongo-sanitize": "^2.2.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "mysql2": "^3.6.5"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
